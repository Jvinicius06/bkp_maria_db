# ====== Conexão MariaDB ======
# Se o MariaDB está no host (Windows/Linux): host.docker.internal
# Se está em outro container Docker: nome do serviço (ex: mariadb)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=backup_user
DB_PASSWORD=troque_esta_senha
DB_NAME=meu_banco

# ====== Google Drive via rclone ======
# Nome do remote configurado no rclone e pasta destino
# Ex: gdrive:backups/mariadb
RCLONE_REMOTE=gdrive:backups/mariadb

# ====== Controle de impacto no banco ======
# Limita throughput do pipe dump->gzip em MB/s. 0 = sem limite.
# Valor baixo = backup mais lento, menos stress no banco.
THROTTLE_MBPS=5

# gzip: 1 (mais rápido, menos CPU) a 9 (melhor compressão).
# Use 1 para bancos em produção; o throttle cuida do tamanho.
GZIP_LEVEL=1

# ====== Retenção ======
# Cópias locais a manter (as mais antigas são apagadas)
LOCAL_RETENTION=3

# Cópias remotas no Drive a manter.
# Para ter ~31 dias de buffer com backup de hora em hora: 744 (24*31).
REMOTE_RETENTION=744

# ====== Agendamento ======
# Cron padrão: todo início de hora. Evite horários de pico.
# Ex para rodar 02h, 06h, 10h...: "0 2,6,10,14,18,22 * * *"
CRON_SCHEDULE=0 * * * *

# Fazer 1 backup imediatamente ao subir o container (útil para testar)
RUN_ON_START=false

TZ=America/Sao_Paulo

# ====== Dashboard web ======
# Senha OBRIGATÓRIA para habilitar a dashboard (deixe vazio = desabilitada).
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=troque_esta_senha_forte
# Porta publicada no host (a dashboard escuta em 8080 dentro do container)
DASHBOARD_PORT=8080
# URL pública pela qual você acessa a dashboard. OBRIGATÓRIA para o re-login
# do Google Drive (é o redirect_uri do OAuth). Sem barra no final.
# Ex: http://SEU_IP_PUBLICO:8080  (ideal: https://backup.seudominio.com)
DASHBOARD_PUBLIC_URL=http://SEU_IP_PUBLICO:8080

# ====== OAuth Google Drive (Client ID próprio) ======
# Crie em console.cloud.google.com -> APIs & Services -> Credentials
# -> OAuth client ID -> tipo "Web application".
# Em "Authorized redirect URIs" coloque EXATAMENTE:
#   ${DASHBOARD_PUBLIC_URL}/oauth/callback
# Se o rclone.conf já tem client_id/secret, estes campos podem ficar vazios.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ====== Discord (alertas de erro) ======
# Webhook do canal onde quer receber os alertas de falha de backup.
# Canal do Discord -> Editar -> Integrações -> Webhooks -> Copiar URL.
DISCORD_WEBHOOK_URL=
# true = também avisa nos backups bem-sucedidos (padrão: só erros)
DISCORD_NOTIFY_SUCCESS=false
# Watchdog: alerta se passar X horas sem backup BEM-SUCEDIDO.
# Com backup de hora em hora, 3 é um bom valor.
BACKUP_MAX_AGE_HOURS=3
